# ══════════════════════════════════════════
# OpenClaude — .gitignore
# Framework files are tracked.
# Personal data, secrets, and runtime output are NOT.
# ══════════════════════════════════════════

# ── Secrets & credentials ─────────────────
.env
.claude/.env

# ── Personal workspace data ───────────────
# Track folder structure (.gitkeep) but ignore all content inside.
01 Daily Logs/*
!01 Daily Logs/.gitkeep
02 Projects/*
!02 Projects/.gitkeep
03 Comunidade/*
!03 Comunidade/.gitkeep
04 Redes Sociais/*
!04 Redes Sociais/.gitkeep
05 Financeiro/*
!05 Financeiro/.gitkeep
06 Pessoal/*
!06 Pessoal/.gitkeep
07 Reuniões/*
!07 Reuniões/.gitkeep
08 Cursos/*
!08 Cursos/.gitkeep
09 Estrategia/*
!09 Estrategia/.gitkeep
09 Reuniões/*
!09 Reuniões/.gitkeep

# ── Agent memory (runtime, personal) ──────
.claude/agent-memory/
memory/

# ── Product-specific (Evolution API proprietary) ─
.claude/skills/int-licensing/
.claude/skills/int-whatsapp/
.claude/skills/prod-licensing-daily/
.claude/skills/prod-licensing-weekly/
.claude/skills/prod-licensing-monthly/
.claude/templates/html/licensing-report.html
ADWs/rotinas/licensing_daily.py
ADWs/rotinas/licensing_weekly.py
ADWs/rotinas/licensing_monthly.py

# ── Runtime data & logs ───────────────────
ADWs/logs/
dashboard/data/*.db
dashboard/data/*.db-shm
dashboard/data/*.db-wal
dashboard/data/.secret_key
dashboard/frontend/node_modules/
dashboard/frontend/dist/

# ── Evo Method output ────────────────────
_evo-output/

# ── Python ────────────────────────────────
.venv/
__pycache__/
*.pyc

# ── OS ────────────────────────────────────
.DS_Store
Thumbs.db

# ── Generated configs (personal) ─────────
CLAUDE.md
config/workspace.yaml

# ── Claude Code session data ─────────────
.claude/projects/
.claude/image-cache/
.claude/todos/
.claude/TASKS.md
