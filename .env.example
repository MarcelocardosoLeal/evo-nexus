# ============================================================
# Evolution Workspace — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ============================================================

# ── Omie ERP ─────────────────────────────────────────
# API do Omie ERP (omie.com.br → Configurações → Integrações → API)
OMIE_APP_KEY=
OMIE_APP_SECRET=

# ── Stripe ───────────────────────────────────────────
# Stripe Secret Key (dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_live_...

# ── Todoist ──────────────────────────────────────────
# Todoist API Token (app.todoist.com → Settings → Integrations → API Token)
TODOIST_API_TOKEN=

# ── Fathom (Meetings) ───────────────────────────────
# Fathom API Key (fathom.video → Settings → API)
FATHOM_API_KEY=

# ── Discord ──────────────────────────────────────────
# Discord Bot Token (discord.com/developers → Bot → Token)
DISCORD_BOT_TOKEN=
# Server Guild ID (enable Developer Mode → copy server ID)
DISCORD_GUILD_ID=

# ── Telegram ─────────────────────────────────────────
# Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=
# User Chat ID (send a message to the bot and get from webhook)
TELEGRAM_CHAT_ID=

# ── WhatsApp (Evolution Foundation API) ──────────────
# API Key to query WhatsApp group messages
WHATSAPP_API_KEY=

# ── Licensing (Evolution Go) ─────────────────────────
# Admin token for licensing API (license.evolutionfoundation.com.br)
LICENSING_ADMIN_TOKEN=

# ── YouTube OAuth ────────────────────────────────────
# Google Cloud Console → APIs → Credentials → OAuth Client
# Redirect URI: http://localhost:8765/callback/youtube
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ── Meta / Instagram OAuth ───────────────────────────
# Facebook App (developers.facebook.com → My Apps → Settings → Basic)
# Redirect URI: https://{ngrok-url}/callback/instagram
META_APP_ID=
META_APP_SECRET=

# ── LinkedIn OAuth ───────────────────────────────────
# LinkedIn App (linkedin.com/developers → My Apps → Auth)
# Redirect URI: https://{ngrok-url}/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Ngrok (para OAuth callbacks HTTPS) ───────────────
# Required for Instagram and LinkedIn (they require HTTPS)
# Run: ngrok http 8765
# NGROK_URL=https://your-subdomain.ngrok-free.dev

# ── Social Accounts ──────────────────────────────────
# Managed automatically by `make social-auth`.
# Do not edit manually — use the web interface.
# Pattern: SOCIAL_{PLATFORM}_{N}_{FIELD}
# Example:
# SOCIAL_YOUTUBE_1_LABEL=My Channel
# SOCIAL_YOUTUBE_1_ACCESS_TOKEN=ya29...
# SOCIAL_YOUTUBE_1_CHANNEL_ID=UC...
